# WeClawBot Bridge 环境变量配置

# 服务端口
PORT=3000

# 管理面板密码（留空则首次访问时设置）
API_KEY=

# 加密密钥（32字节十六进制，用于加密存储的凭证）
# 可通过 node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" 生成
ENCRYPTION_KEY=

# 存储目录（Railway/Docker 持久卷请使用 /data）
STORAGE_DIR=

# 日志级别: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# 会话配置
SESSION_MAX_ROUNDS=0
SESSION_EXPIRE_MS=0

# CORS 允许的源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000

# Webhook 密钥（可选，设置后外部调用需携带 X-Webhook-Secret 头）
# 未设置时 Webhook 使用管理面板的 Bearer Token 认证
WEBHOOK_SECRET=
